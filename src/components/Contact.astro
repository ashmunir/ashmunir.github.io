---
import Icon from './Icon.tsx';
import SectionHeading from './SectionHeading.astro';
import { profile } from '../data/portfolio';

const year = new Date().getFullYear();
---

<section id="contact" class="mt-[112px] scroll-mt-8">
  <SectionHeading icon="contact" title="Contact" class="mb-8" />
  <h3 class="m-0 text-[clamp(28px,4vw,42px)] leading-[1.1] tracking-[-0.8px] text-ink">
    Let's work together.
  </h3>
  <p class="mb-7 mt-4 max-w-[520px] text-pretty text-[clamp(15.5px,4.4vw,17px)] text-slate-600">
    Feel free to reach out if you'd like to collaborate, discuss a role, or just say hello.
  </p>
  <a
    href={`mailto:${profile.email}`}
    class="inline-flex items-center gap-3 border-b-2 border-[#CBD5E1] pb-1 text-[clamp(20px,2.6vw,28px)] font-bold text-brand transition-colors hover:border-brand hover:text-ink"
  >
    {profile.email}
    <Icon name="arrow-up-right" size={24} strokeWidth={2} />
  </a>
  <div class="mt-9 flex flex-wrap gap-3">
    <a
      href={`mailto:${profile.email}`}
      class="inline-flex items-center gap-2.5 rounded-xl bg-brand px-5 py-3 text-[15px] font-bold text-white shadow-[0_8px_20px_rgba(44,92,154,0.26)] transition-colors hover:bg-ink"
    >
      <Icon name="mail" size={19} />
      Email
    </a>
    <a
      href={profile.linkedin}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2.5 rounded-xl border border-[#E2E8F0] bg-[#F1F6FC] px-5 py-3 text-[15px] font-bold text-ink transition-colors hover:border-brand hover:bg-[#EAF2FB]"
    >
      <Icon name="linkedin" size={19} />
      LinkedIn
    </a>
    <a
      href={profile.github}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2.5 rounded-xl border border-[#E2E8F0] bg-[#F1F6FC] px-5 py-3 text-[15px] font-bold text-ink transition-colors hover:border-brand hover:bg-[#EAF2FB]"
    >
      <Icon name="github" size={19} />
      ashmunir
    </a>
    <a
      href={profile.githubSecondary}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-2.5 rounded-xl border border-[#E2E8F0] bg-[#F1F6FC] px-5 py-3 text-[15px] font-bold text-slate-500 transition-colors hover:border-brand hover:bg-[#EAF2FB]"
    >
      <Icon name="github" size={19} />
      AyeshaMunirS
    </a>
  </div>
  <div class="mt-16 border-t border-[#EEF2F7] pt-6 text-[13.5px] text-slate-400">
    © {year} {profile.name} · {profile.location}
  </div>
</section>
