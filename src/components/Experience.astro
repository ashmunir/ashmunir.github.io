---
import Icon from './Icon.tsx';
import SectionHeading from './SectionHeading.astro';
import { experiences } from '../data/portfolio';
---

<section id="experience" class="mt-[104px] scroll-mt-8">
  <SectionHeading icon="experience" title="Experience" class="mb-9" />
  <div class="flex flex-col">
    {experiences.map((job) => (
      <div class="pf-exp-row border-b border-[#EEF2F7] py-[26px]">
        <div>
          <div class="text-[14px] font-bold tabular-nums text-ink">{job.period}</div>
          <div class="mt-1 text-[13px] text-slate-400">{job.place}</div>
        </div>
        <div>
          <h3 class="m-0 text-[clamp(18px,4.6vw,20px)] text-ink">{job.title}</h3>
          <a
            href={job.orgUrl}
            target="_blank"
            rel="noopener"
            class="mb-3 mt-[3px] inline-flex items-center gap-1.5 text-[15px] font-bold text-brand transition-colors hover:text-teal"
          >
            {job.org}
            <Icon name="external" size={13} strokeWidth={2} />
          </a>
          <ul class="m-0 flex list-none flex-col gap-[7px] p-0">
            {job.bullets.map((b) => (
              <li class="relative text-pretty pl-5 text-[15px] text-slate-600">
                <span class="absolute left-0 top-[10px] h-1.5 w-1.5 rounded-full bg-[#67A8DC]"></span>
                {b}
              </li>
            ))}
          </ul>
          <div class="mt-3.5 flex flex-wrap gap-[7px]">
            {job.stack.map((t) => (
              <span class="text-[12.5px] font-bold text-slate-500">{t}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
