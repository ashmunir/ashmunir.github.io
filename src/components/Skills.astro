---
import Icon from './Icon.tsx';
import SectionHeading from './SectionHeading.astro';
import { skillGroups } from '../data/portfolio';
---

<section id="skills" class="pf-section-wide mt-[104px] scroll-mt-8">
  <SectionHeading icon="skills" title="Skills & tools" class="mb-9" />
  <div class="grid grid-cols-1 gap-[18px] md:grid-cols-2 xl:grid-cols-3">
    {skillGroups.map((g) => (
      <div class="rounded-[18px] border border-[#E9EEF4] bg-white p-[22px_22px_20px] shadow-[0_1px_2px_rgba(15,44,82,0.04)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-1 hover:border-[#CBD5E1] hover:shadow-[0_16px_34px_rgba(15,44,82,0.1)]">
        <div class="mb-4 flex items-center gap-3">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-[#E1F4F6] to-[#DCEEFA] text-[#0E7C8A]">
            <Icon name={g.icon} size={23} />
          </span>
          <h3 class="m-0 text-[clamp(15px,4vw,16px)] font-bold leading-[1.15] text-ink">{g.title}</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {g.items.map((i) => (
            <span class="cursor-default rounded-full border border-[#E6EDF5] bg-[#F5F8FC] px-[13px] py-1.5 text-[13px] font-bold text-slate-700 transition-colors hover:border-[#BFD8F2] hover:bg-[#EAF2FB] hover:text-ink">
              {i}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
