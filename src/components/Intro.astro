---
import Icon from './Icon.tsx';
import { profile, aboutParagraphs } from '../data/portfolio';
---

<section id="about" class="scroll-mt-8">
  <div class="flex flex-col-reverse items-center gap-7 sm:flex-row sm:items-center sm:justify-between sm:gap-10">
    <div class="text-center sm:text-left">
      <h2 class="m-0 text-[clamp(32px,4.4vw,50px)] font-bold leading-[1.08] tracking-[-1.2px] text-ink">
        Hi, I'm Ayesha <span aria-hidden="true">👋</span>
      </h2>
      <p class="mt-4 text-[clamp(16px,2vw,20px)] font-bold text-brand">{profile.roleLine}</p>
    </div>
    <div class="pf-portrait relative shrink-0">
      <div class="absolute -inset-1.5 rounded-full bg-gradient-to-br from-teal to-brand opacity-85"></div>
      <div class="pf-portrait-frame relative aspect-square overflow-hidden rounded-full border-4 border-white shadow-[0_16px_36px_rgba(15,44,82,0.2)]">
        <img
          src={profile.avatar}
          alt="Ayesha Munir"
          width="120"
          height="120"
          class="block h-full w-full object-cover"
          style="object-position:50% 50%"
        />
      </div>
    </div>
  </div>

  <div class="mt-10 rounded-[22px] border border-[#EAEFF5] bg-white p-[34px_38px] shadow-[0_4px_20px_rgba(15,44,82,0.05)]">
    <div class="flex flex-col gap-4">
      {aboutParagraphs.map((p, i) => (
        <p class={`m-0 text-pretty text-slate-600 ${i === 0 ? 'text-[clamp(15.5px,4.4vw,17px)]' : 'text-[clamp(15px,4.2vw,16px)]'}`}>{p}</p>
      ))}
    </div>
    <div class="mt-7 flex flex-wrap gap-3">
      <a
        href="#contact"
        class="inline-flex items-center gap-2.5 rounded-full bg-brand px-6 py-3.5 text-[15px] font-bold text-white shadow-[0_8px_20px_rgba(44,92,154,0.26)] transition-colors hover:bg-ink"
      >
        Get in touch
        <Icon name="arrow-right" size={17} strokeWidth={2} />
      </a>
      <a
        href={profile.resumeUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2.5 rounded-full border border-[#CBD5E1] bg-white px-6 py-3.5 text-[15px] font-bold text-ink transition-colors hover:border-brand hover:bg-[#F7FAFD]"
      >
        <Icon name="download" size={17} strokeWidth={1.9} />
        Resume
      </a>
    </div>
  </div>
</section>
