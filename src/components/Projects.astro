---
import Icon from './Icon.tsx';
import SectionHeading from './SectionHeading.astro';
import { projects } from '../data/portfolio';
---

<section id="projects" class="mt-[104px] scroll-mt-8">
  <SectionHeading icon="projects" title="Projects" class="mb-2" />
  <p class="mb-6 mt-3.5 text-[14px] text-slate-400">
    Most work is under client / NDA repositories — happy to walk through the details on request.
  </p>
  <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
    {projects.map((p) => (
      <a
        href={p.href}
        target={p.target}
        rel={p.target === '_blank' ? 'noopener' : undefined}
        class="group flex flex-col rounded-[18px] border border-[#E9EEF4] bg-white p-[24px_24px_22px] shadow-[0_1px_2px_rgba(15,44,82,0.04)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-1 hover:border-[#CBD5E1] hover:shadow-[0_16px_34px_rgba(15,44,82,0.1)]"
      >
        <div class="mb-1 flex flex-wrap items-center gap-2.5">
          <h3 class="m-0 text-[clamp(16.5px,4.2vw,18px)] text-ink">{p.name}</h3>
          <span class="rounded-full bg-[#EAF2FB] px-2.5 py-[3px] text-[12px] font-bold text-brand">{p.tag}</span>
        </div>
        <div class="mb-2.5 text-[13px] text-slate-400">{p.org}</div>
        <p class="m-0 flex-1 text-pretty text-[14.5px] text-slate-600">{p.desc}</p>
        <div class="mt-3 flex flex-wrap gap-[7px]">
          {p.stack.map((t) => (
            <span class="text-[12.5px] font-bold text-slate-500">{t}</span>
          ))}
        </div>
        <div class="mt-4 inline-flex items-center gap-1.5 text-[13.5px] font-bold text-brand transition-colors group-hover:text-teal">
          <Icon name={p.target === '_blank' ? 'external' : 'arrow-right'} size={15} strokeWidth={2} />
          {p.target === '_blank' ? 'Visit site' : 'Learn more'}
        </div>
      </a>
    ))}
  </div>
</section>
